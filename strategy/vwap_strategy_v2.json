{
  "strategy": {
    "name": "VWAP Mean Reversion + Volume Delta Confirmation",
    "version": "2.1.0",
    "type": "mean_reversion",
    "mode": "auto",
    "description": "v2.1 — multi-instrument + multi-timeframe config. Python engine loops instruments array, applies per-symbol params, executes directly via MetaTrader5 library.",
    "changelog_from_v2": [
      "ADDED: instruments[] array — per-symbol params (spread, multipliers, pip_value, kill_zones, ADX threshold)",
      "ADDED: timeframe_config — execution/confirmation/htf_bias/macro_bias/backtest_all",
      "ADDED: mt5_timeframe_map — string to mt5.TIMEFRAME_XX lookup for Python engine",
      "ADDED: multi_instrument_rules — how Python engine loops and manages positions per symbol",
      "CHANGED: strategy.instrument removed — now driven by instruments[] array",
      "CHANGED: strategy.timeframe removed — now driven by timeframe_config.execution",
      "CHANGED: mt5_connection.symbol removed — engine iterates instruments[]",
      "CHANGED: backtest now references instruments[] and timeframe_config.backtest_all"
    ]
  },

  "timeframe_config": {
    "execution":    "M5",
    "confirmation": "M15",
    "htf_bias":     "H1",
    "macro_bias":   "H4",
    "backtest_all": ["M5", "M15", "M30"],
    "notes": {
      "execution":    "Signal trigger and order entry timeframe",
      "confirmation": "M15 must agree with signal before M5 entry fires",
      "htf_bias":     "H1 EMA50 determines preferred direction (long/short bias)",
      "macro_bias":   "H4 trend filters out counter-macro trades — optional, high-conviction filter",
      "backtest_all": "Run full backtest on all three, keep timeframe with best Sharpe + profit factor"
    }
  },

  "mt5_timeframe_map": {
    "M1":  "mt5.TIMEFRAME_M1",
    "M5":  "mt5.TIMEFRAME_M5",
    "M15": "mt5.TIMEFRAME_M15",
    "M30": "mt5.TIMEFRAME_M30",
    "H1":  "mt5.TIMEFRAME_H1",
    "H4":  "mt5.TIMEFRAME_H4",
    "D1":  "mt5.TIMEFRAME_D1"
  },

